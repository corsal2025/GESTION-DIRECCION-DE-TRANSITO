@page "/"

<PageTitle>🏛️ Hub - Gestión Dirección de Tránsito</PageTitle>

<div class="hub-container">
    <div class="hub-header">
        <div class="header-content">
            <h1 class="hub-title">🏛️ Hub Municipal</h1>
            <p class="hub-subtitle">Gestión Centralizada de Trámites - Dirección de Tránsito</p>
        </div>
    </div>

    <!-- Estadísticas Principales -->
    <div class="container stats-section">
        <h2 class="section-title">📊 Estadísticas Generales</h2>

        <div class="grid">
            <div class="grid-item">
                <div class="stat-card stat-card-primary">
                    <div class="stat-icon">📋</div>
                    <div class="stat-value">@TotalTramites</div>
                    <div class="stat-label">Trámites Totales</div>
                </div>
            </div>

            <div class="grid-item">
                <div class="stat-card stat-card-success">
                    <div class="stat-icon">✅</div>
                    <div class="stat-value">@TramitesCompletados</div>
                    <div class="stat-label">Completados</div>
                </div>
            </div>

            <div class="grid-item">
                <div class="stat-card stat-card-warning">
                    <div class="stat-icon">⏳</div>
                    <div class="stat-value">@TramitesEnProceso</div>
                    <div class="stat-label">En Proceso</div>
                </div>
            </div>

            <div class="grid-item">
                <div class="stat-card stat-card-danger">
                    <div class="stat-icon">❌</div>
                    <div class="stat-value">@TramitesRechazados</div>
                    <div class="stat-label">Rechazados</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Módulos Municipales -->
    <div class="container modules-section">
        <h2 class="section-title">🎯 Módulos Disponibles</h2>

        <div class="grid grid-3">
            @foreach (var modulo in Modulos)
            {
                <div class="grid-item">
                    <div class="modulo-card">
                        <div class="card-icon">@modulo.Icon</div>
                        <h3 class="modulo-title">@modulo.Nombre</h3>
                        <p class="modulo-description">@modulo.Descripcion</p>

                        <hr class="divider" />

                        <div class="modulo-stats">
                            <div class="stat-row">
                                <span class="stat-label-small">Registros:</span>
                                <span class="stat-value-small">@modulo.CantidadRegistros</span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label-small">Estado:</span>
                                <span class="chip chip-success">@modulo.Estado</span>
                            </div>
                        </div>

                        <button class="btn btn-primary btn-full">Ver Módulo →</button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Últimas Actividades -->
    <div class="container activity-section">
        <h2 class="section-title">📜 Últimas Actividades</h2>

        <div class="activity-list">
            @if (UltimasActividades.Any())
            {
                @foreach (var actividad in UltimasActividades)
                {
                    <div class="activity-item">
                        <div class="activity-icon">@actividad.Icon</div>
                        <div class="activity-content">
                            <div class="activity-title">@actividad.Titulo</div>
                            <div class="activity-description">@actividad.Descripcion</div>
                            <div class="activity-time">@actividad.Fecha.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    </div>
                    <hr class="divider" />
                }
            }
            else
            {
                <p class="no-data">Sin actividades registradas</p>
            }
        </div>
    </div>

    <!-- Sección de Acciones Rápidas -->
    <div class="container actions-section">
        <h2 class="section-title">⚡ Acciones Rápidas</h2>

        <div class="grid grid-4">
            <div class="grid-item">
                <button class="btn btn-primary btn-full btn-lg">➕ Nuevo Trámite</button>
            </div>
            <div class="grid-item">
                <button class="btn btn-secondary btn-full btn-lg">🔍 Buscar Trámite</button>
            </div>
            <div class="grid-item">
                <button class="btn btn-info btn-full btn-lg">📊 Reportes</button>
            </div>
            <div class="grid-item">
                <button class="btn btn-warning btn-full btn-lg">⚙️ Configuración</button>
            </div>
        </div>
    </div>
</div>

@code {
    private int TotalTramites = 1250;
    private int TramitesCompletados = 845;
    private int TramitesEnProceso = 310;
    private int TramitesRechazados = 95;

    private List<ModuloInfo> Modulos = new();
    private List<ActividadInfo> UltimasActividades = new();

    protected override void OnInitialized()
    {
        CargarModulos();
        CargarActividades();
    }

    private void CargarModulos()
    {
        Modulos = new List<ModuloInfo>
        {
            new("Gestión F8", "📁 Documentos Administrativos", "Gestiona documentos y carpetas", 245, "Activo"),
            new("Módulo 12", "📋 Gestión Administrativa", "Trámites administrativos con folio", 156, "Activo"),
            new("Módulo 16", "🔖 Registro Interno", "Sistema de registro interno", 89, "Activo"),
            new("Hoja de Ruta", "🛤️ Trazabilidad", "Seguimiento de etapas del proceso", 312, "Activo"),
            new("Examen Psicométrico", "🧠 Evaluación Psicológica", "Evaluación psicométrica para licencias", 156, "Activo"),
            new("Examen Teórico", "📚 Evaluación Teórica", "Examen de leyes de tránsito", 234, "Activo"),
            new("Cambio Domicilio", "🏠 Actualización de Domicilio", "Cambios de domicilio del titular", 67, "Activo"),
            new("Gestión Licencias", "🎫 Licencias de Conducir", "Emisión y gestión de licencias", 445, "Activo")
        };
    }

    private void CargarActividades()
    {
        UltimasActividades = new List<ActividadInfo>
        {
            new("✅", "Trámite completado", "RUT: 12.345.678-K - Gestión F8", DateTime.Now.AddHours(-1)),
            new("⏳", "En proceso", "RUT: 23.456.789-1 - Módulo 12", DateTime.Now.AddHours(-2)),
            new("🔄", "Estado actualizado", "RUT: 34.567.890-K - Hoja de Ruta", DateTime.Now.AddHours(-3)),
            new("📝", "Nuevo registro", "RUT: 45.678.901-9 - Examen Teórico", DateTime.Now.AddHours(-4)),
            new("✅", "Aprobado", "RUT: 56.789.012-8 - Examen Psicométrico", DateTime.Now.AddHours(-5))
        };
    }

    public class ModuloInfo
    {
        public string Nombre { get; }
        public string Icon { get; }
        public string Descripcion { get; }
        public int CantidadRegistros { get; }
        public string Estado { get; }

        public ModuloInfo(string nombre, string icon, string descripcion, int cantidad, string estado)
        {
            Nombre = nombre;
            Icon = icon;
            Descripcion = descripcion;
            CantidadRegistros = cantidad;
            Estado = estado;
        }
    }

    public class ActividadInfo
    {
        public string Icon { get; }
        public string Titulo { get; }
        public string Descripcion { get; }
        public DateTime Fecha { get; }

        public ActividadInfo(string icon, string titulo, string descripcion, DateTime fecha)
        {
            Icon = icon;
            Titulo = titulo;
            Descripcion = descripcion;
            Fecha = fecha;
        }
    }
}

